package Exercícios;

import java.util.Scanner;

public class ExercícioRepetição {

	public static void main(String[] args) {
		int countPar = 0, countImpar = 0, num = 0, totalPar = 0, totalImpar = 0;
		Scanner ler = new Scanner(System.in);

		do {

			System.out.println("Digite um número: ");
			num = ler.nextInt();

			if (num % 2 == 0) {
				countPar++;
				totalPar = totalPar + num;
			} else {
				countImpar++;
				totalImpar = totalImpar + num;
			}

		} while (countPar < 10);
		System.out.println("Soma dos pares: " + totalPar);
		System.out.println("Média dos impares: " + totalImpar / countImpar);

	}

}
